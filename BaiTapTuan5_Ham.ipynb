    "W5A1\n",
    "Viết hàm truyền vào hai số nguyên a, b. Trả về số lớn hơn trong hai số. def Max_Of_Two( a, b) ->\n",
    "int"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "227883c3",
   "metadata": {},
   "outputs": [],
   "source": [
    "def Max_Of_Two(a, b):\n",
    "    if a > b:\n",
    "        return a\n",
    "    else:\n",
    "        return b\n",
    "a, b = map(int, input().split())\n",
    "print(Max_Of_Two(a, b))"
   ]
  }
